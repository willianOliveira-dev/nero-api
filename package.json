{
  "name": "nero-api",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run build:ts && tsc -p test/tsconfig.json && c8 node --test --import=tsx \"test/**/*.ts\"",
    "dev": "tsx --watch --env-file=.env src/server.ts",
    "build": "tsc && cp -r public dist/public",
    "dev:start": "node dist/server.ts",
    "drizzle:migrate": "npx drizzle-kit generate && npx drizzle-kit migrate"
  },
  "engines": {
    "node": "24.x"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@neondatabase/serverless": "^1.0.2",
    "@scalar/fastify-api-reference": "^1.48.5",
    "better-auth": "^1.5.4",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.4.1",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "uuidv7": "^1.1.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.0.8",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "c8": "^10.1.2",
    "concurrently": "^9.0.0",
    "ts-node": "^10.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
